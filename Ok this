function parsePrice(str) {
  var m = String(str).match(/[\d.]+/);
  return m ? parseFloat(m[0]) : 0;
}
function cartTotal() {
  var s = 0;
  for (var i = 0; i < cart.length; i++) s += cart[i].priceNum * cart[i].qty;
  return s;
}
function cartCount() {
  var s = 0;
  for (var i = 0; i < cart.length; i++) s += cart[i].qty;
  return s;
}

function addToCart(pid, ti) {
  var p = null;
  for (var i = 0; i < products.length; i++) {
    if (products[i].id === pid) { p = products[i]; break; }
  }
  if (!p || !p.tiers || !p.tiers[ti]) return;
  var t = p.tiers[ti];
  var key = pid + '-' + ti;
  var found = false;
  for (var j = 0; j < cart.length; j++) {
    if (cart[j].key === key) { cart[j].qty++; found = true; break; }
  }
  if (!found) {
    cart.push({key:key, id:pid, name:p.name, emoji:p.emoji,
      tierLabel:t.label, tierPrice:t.price, priceNum:parsePrice(t.price), qty:1});
  }
  syncCartUI();
}

function removeFromCart(key) {
  var next = [];
  for (var i = 0; i < cart.length; i++) {
    if (cart[i].key !== key) next.push(cart[i]);
  }
  cart = next;
  syncCartUI();
}

function changeQty(key, delta) {
  for (var i = 0; i < cart.length; i++) {
    if (cart[i].key === key) { cart[i].qty += delta; break; }
  }
  var next = [];
  for (var j = 0; j < cart.length; j++) {
    if (cart[j].qty > 0) next.push(cart[j]);
  }
  cart = next;
  syncCartUI();
}

function syncCartUI() {
  var count = cartCount();
  var total = cartTotal();

  // Bar visibility
  document.getElementById('cartBar').style.display = count > 0 ? 'flex' : 'none';
  document.getElementById('cartCount').textContent = count;

  // Preview text
  var preview = document.getElementById('cartTotalPreview');
  if (count > 0) {
    preview.innerHTML = 'Cart &middot; <span>$' + total.toFixed(2) + '</span>';
  } else {
    preview.textContent = 'Cart';
  }

  // Update all add buttons
  var btns = document.querySelectorAll('.add-btn');
  for (var b = 0; b < btns.length; b++) {
    var btn = btns[b];
    var bpid = parseInt(btn.getAttribute('data-pid'), 10);
    var bti  = parseInt(btn.getAttribute('data-ti'), 10);
    var bkey = bpid + '-' + bti;
    var inCart = null;
    for (var c = 0; c < cart.length; c++) {
      if (cart[c].key === bkey) { inCart = cart[c]; break; }
    }
    if (inCart) {
      btn.textContent = '\u2713 ' + inCart.qty;
      btn.style.background = 'rgba(168,255,110,0.2)';
      btn.style.borderColor = 'rgba(168,255,110,0.5)';
    } else {
      btn.textContent = '+ Add';
      btn.style.background = '';
      btn.style.borderColor = '';
    }
  }

  // Cart drawer items
  var el = document.getElementById('cartItems');
  if (cart.length === 0) {
    el.innerHTML = '<div class="cart-empty"><div class="cart-empty-icon">&#x1F6D2;</div>Your cart is empty</div>';
  } else {
    var html = '';
    for (var k = 0; k < cart.length; k++) {
      var item = cart[k];
      html +=
        '<div class="cart-item">' +
          '<div class="ci-emoji">' + item.emoji + '</div>' +
          '<div class="ci-info">' +
            '<div class="ci-name">' + item.name + '</div>' +
            '<div class="ci-tier">' + item.tierLabel + ' &middot; ' + item.tierPrice + '</div>' +
            '<div class="ci-qty">' +
              '<button class="qty-btn" onclick="changeQty(\'' + item.key + '\',-1)">&#x2212;</button>' +
              '<span class="qty-num">' + item.qty + '</span>' +
              '<button class="qty-btn" onclick="changeQty(\'' + item.key + '\',1)">+</button>' +
            '</div>' +
          '</div>' +
          '<div class="ci-right">' +
            '<button class="ci-remove" onclick="removeFromCart(\'' + item.key + '\')">&#x2715;</button>' +
            '<div class="ci-price">$' + (item.priceNum * item.qty).toFixed(2) + '</div>' +
          '</div>' +
        '</div>';
    }
    el.innerHTML = html;
  }

  // Subtotal
  document.getElementById('cartSubtotal').textContent = '$' + total.toFixed(2);

  // Update pickup location and form state
  updatePickupLocation();
  onFormChange();
}

