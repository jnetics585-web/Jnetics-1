  var fulfillLabel = fulfillMethod === 'pickup'
    ? (cartHasFlower() && cartHasConcentrate() ? 'Pickup — LA (flower) + SF (concentrates)' : cartHasFlower() ? 'Pickup — Los Angeles' : 'Pickup — San Francisco')
    : 'Ship to: ' + addr + ', ' + city + ' ' + state + ' ' + zip;

  var body = {
    _subject: 'New J-netics Order from ' + name,
    Name: name,
    Email: email,
    Phone: phone,
    'Order Total': '$' + cartTotal().toFixed(2),
    'Order Items': parts.join(' | '),
    Fulfillment: fulfillLabel
  };

  try {
    var resp = await fetch('https://formspree.io/f/jneetics585@gmail.com', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(body)
    });
    if (resp.ok) {
      orderSent = true;
      btn.textContent = '\u2713 Order Sent!';
      btn.className = 'send-order-btn sent';
      if (note) { note.textContent = 'Got it! Now complete your payment below.'; note.style.color = 'var(--accent)'; }
      unlockPayment();
    } else {
      throw new Error('Server error');
    }
  } catch(e) {
    btn.textContent = 'Send Order Info \u2192';
    btn.className = 'send-order-btn ready';
    if (note) { note.textContent = 'Something went wrong. Please try again.'; note.style.color = '#f87171'; }
  }
}

// ── Filtering & Rendering ─────────────────────────────
var activeTab = 'all';
var searchQuery = '';
var sortBy = 'default';
var typeFilter = 'all';

function getFiltered() {
  var list = products.slice();
  if (activeTab !== 'all') {
    var tmp = [];
    for (var i = 0; i < list.length; i++) {
      if (list[i].cat === activeTab) tmp.push(list[i]);
    }
    list = tmp;
  }
  if (typeFilter !== 'all') {
    var tmp2 = [];
    for (var i = 0; i < list.length; i++) {
      if (list[i].strain === typeFilter) tmp2.push(list[i]);
    }
    list = tmp2;
  }
  if (searchQuery) {
    var q = searchQuery.toLowerCase();
    var tmp3 = [];
    for (var i = 0; i < list.length; i++) {
      var p = list[i];
      if (p.name.toLowerCase().indexOf(q) >= 0 || p.brand.toLowerCase().indexOf(q) >= 0 ||
          p.desc.toLowerCase().indexOf(q) >= 0 || p.strain.toLowerCase().indexOf(q) >= 0) {
        tmp3.push(p);
      }
    }
    list = tmp3;
  }
  if (sortBy === 'name-asc') {
    list.sort(function(a,b){ return a.name.localeCompare(b.name); });
  }
  return list;
}

function strainColor(s) {
  if (s === 'indica') return 'var(--indica)';
  if (s === 'sativa') return 'var(--sativa)';
  if (s === 'hybrid') return 'var(--hybrid)';
  return 'var(--accent)';
}

function renderCard(p, idx) {
  var badgeClass = 'badge-' + p.strain;
  var stockDot = p.stock === 'low' ? ' low' : '';
  var stockText = p.stock === 'low' ? 'Low Stock' : 'In Stock';

  var tiersHtml = '';
  if (p.tiers && p.tiers.length > 0) {
    var rows = '';
    for (var ti = 0; ti < p.tiers.length; ti++) {
      var t = p.tiers[ti];
      var key = p.id + '-' + ti;
      var cartItem = null;
      for (var ci = 0; ci < cart.length; ci++) {
        if (cart[ci].key === key) { cartItem = cart[ci]; break; }
      }
      var btnStyle = cartItem ? 'background:rgba(168,255,110,0.2);border-color:rgba(168,255,110,0.5);' : '';
      var btnText  = cartItem ? ('\u2713 ' + cartItem.qty) : '+ Add';
      rows +=
        '<div class="tier-row">' +
          '<span class="tier-label">' + t.label + '</span>' +
          '<div style="display:flex;align-items:center;gap:0.5rem">' +
            '<span class="tier-price">' + t.price + '</span>' +
            '<button class="add-btn" data-pid="' + p.id + '" data-ti="' + ti + '" onclick="addToCart(' + p.id + ',' + ti + ')" style="' + btnStyle + '">' + btnText + '</button>' +
          '</div>' +
        '</div>';
    }
    tiersHtml = '<div class="price-tiers">' + rows + '</div>';
  }

  return '<div class="card" style="--strain-color:' + strainColor(p.strain) + ';animation-delay:' + (idx * 0.04) + 's">' +
    '<div class="card-header">' +
      '<div class="card-emoji">' + p.emoji + '</div>' +
      '<span class="strain-badge ' + badgeClass + '">' + p.strain + '</span>' +
    '</div>' +
    '<div>' +
      '<div class="card-name">' + p.name + '</div>' +
      '<div class="card-brand">' + p.brand + '</div>' +
    '</div>' +
    '<div class="card-strain-desc">' + p.strainDesc + '</div>' +
    '<div class="card-desc">' + p.desc + '</div>' +
    tiersHtml +
    '<div class="card-footer">' +
      '<div class="availability"><span class="dot' + stockDot + '"></span>' + stockText + '</div>' +
    '</div>' +
  '</div>';
}

function updateCounts() {
  var counts = {all:0, flower:0, concentrate:0, preroll:0};
  for (var i = 0; i < products.length; i++) {
    counts.all++;
    var cat = products[i].cat;
    if (counts.hasOwnProperty(cat)) counts[cat]++;
  }
  for (var key in counts) {
    var el = document.getElementById('cnt-' + key);
    if (el) el.textContent = counts[key];
  }
}

function render() {
  var list = getFiltered();
  document.getElementById('resultCount').innerHTML = '<span>' + list.length + '</span> product' + (list.length !== 1 ? 's' : '');
  var grid = document.getElementById('productGrid');
  if (list.length === 0) {
    grid.innerHTML = '<div class="empty"><div class="empty-icon">🌿</div><div class="empty-title">Nothing found</div><div class="empty-sub">Try adjusting your filters</div></div>';
    return;
  }
  var html = '';
  for (var i = 0; i < list.length; i++) html += renderCard(list[i], i);
  grid.innerHTML = html;
}

// Events
document.getElementById('tabs').addEventListener('click', function(e) {
  var t = e.target;
  while (t && !t.classList.contains('tab')) t = t.parentElement;
  if (!t) return;
  var all = document.querySelectorAll('.tab');
  for (var i = 0; i < all.length; i++) all[i].classList.remove('active');
  t.classList.add('active');
  activeTab = t.getAttribute('data-cat');
  render();
});
document.getElementById('searchInput').addEventListener('input', function(e) {
  searchQuery = e.target.value.trim();
  render();
});
document.getElementById('sortSelect').addEventListener('change', function(e) {
  sortBy = e.target.value;
  render();
});
document.getElementById('typeFilter').addEventListener('change', function(e) {
  typeFilter = e.target.value;
  render();
});

// Init
updateCounts();
render();
syncCartUI();
onFormChange();
</script>

