<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>J-netics — Menu</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #000000;
    --surface: #0c0c0e;
    --surface2: #121214;
    --surface3: #18181b;
    --border: #222427;
    --border-light: #2a2d32;
    --accent: #a8ff6e;
    --accent2: #7ddd46;
    --muted: #3a3d44;
    --text: #e8eaed;
    --text-dim: #5c6070;
    --text-mid: #9499a8;
    --indica: #a78bfa;
    --sativa: #fb923c;
    --hybrid: #a8ff6e;
    --cbd: #38bdf8;
    --radius: 12px;
    --radius-sm: 6px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: linear-gradient(135deg, #000000 0%, #0a0a0f 40%, #000008 70%, #000000 100%);
    background-attachment: fixed;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    padding-bottom: 5rem;
  }
  body::before {
    content: '';
    position: fixed; top: -30%; left: 20%;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(168,255,110,0.05) 0%, transparent 65%);
    pointer-events: none; z-index: 0;
  }

/* HEADER */
header {
position: sticky; top: 0; z-index: 10;
padding: 1.5rem 2rem;
border-bottom: 1px solid var(–border);
display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
background: rgba(0,0,0,0.9);
backdrop-filter: blur(12px);
}
.logo-eyebrow { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.2em; color: var(–accent2); text-transform: uppercase; margin-bottom: 0.3rem; }
.logo { font-family: ‘Syne’, sans-serif; font-size: 1.6rem; font-weight: 700; color: #fff; }
.logo em { font-style: normal; color: var(–accent); }
.open-badge {
display: inline-flex; align-items: center; gap: 0.5rem;
font-size: 0.7rem; font-weight: 500; color: var(–text-mid);
background: var(–surface2); border: 1px solid var(–border-light);
padding: 0.4rem 0.9rem; border-radius: 100px;
}
.open-badge::before {
content: ‘’; width: 6px; height: 6px; border-radius: 50%;
background: var(–accent); box-shadow: 0 0 8px var(–accent);
animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

/* MAIN */
main { position: relative; z-index: 10; max-width: 1400px; margin: 0 auto; padding: 2rem; }

/* CONTROLS */
.controls { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.search-wrap { position: relative; flex: 1; min-width: 200px; max-width: 360px; }
.search-icon { position: absolute; left: 0.9rem; top: 50%; transform: translateY(-50%); color: var(–muted); pointer-events: none; }
.search-input {
width: 100%; background: var(–surface2); border: 1px solid var(–border-light); border-radius: var(–radius-sm);
color: var(–text); font-family: ‘Inter’, sans-serif; font-size: 0.8rem;
padding: 0.65rem 1rem 0.65rem 2.4rem; outline: none;
}
.search-input:focus { border-color: rgba(168,255,110,0.4); box-shadow: 0 0 0 3px rgba(168,255,110,0.07); }
.search-input::placeholder { color: var(–text-dim); }
.filter-select {
background: var(–surface2); border: 1px solid var(–border-light); border-radius: var(–radius-sm);
color: var(–text); font-family: ‘Inter’, sans-serif; font-size: 0.78rem;
padding: 0.6rem 0.9rem; outline: none; cursor: pointer;
}
.result-count { margin-left: auto; font-size: 0.72rem; font-weight: 500; color: var(–text-dim); white-space: nowrap; }
.result-count span { color: var(–accent); }

/* TABS */
.tabs { display: flex; gap: 0.25rem; margin-bottom: 2rem; overflow-x: auto; scrollbar-width: none; }
.tabs::-webkit-scrollbar { display: none; }
.tab {
padding: 0.5rem 1rem; font-family: ‘Inter’, sans-serif; font-size: 0.78rem; font-weight: 500;
color: var(–text-dim); cursor: pointer; border: 1px solid transparent; border-radius: var(–radius-sm);
background: none; white-space: nowrap; display: flex; align-items: center; gap: 0.4rem; transition: all 0.15s;
}
.tab:hover { color: var(–text); background: var(–surface2); }
.tab.active { color: var(–accent); background: rgba(168,255,110,0.08); border-color: rgba(168,255,110,0.2); }
.tab-count {
display: inline-flex; align-items: center; justify-content: center;
min-width: 18px; height: 18px; padding: 0 4px;
background: var(–surface3); font-size: 0.62rem; font-weight: 600; color: var(–text-dim); border-radius: 4px;
}
.tab.active .tab-count { background: rgba(168,255,110,0.15); color: var(–accent); }

/* GRID */
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px,1fr)); gap: 1rem; }

/* CARD */
.card {
background: var(–surface); border: 1px solid var(–border); border-radius: var(–radius);
padding: 1.25rem; display: flex; flex-direction: column; gap: 0.85rem;
animation: fadeIn 0.35s ease both;
transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
position: relative; overflow: hidden;
}
.card:hover { background: var(–surface2); border-color: var(–border-light); box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
.card::after {
content: ‘’; position: absolute; top: 0; left: 0; right: 0; height: 1px;
background: linear-gradient(90deg, transparent, var(–strain-color, var(–accent)), transparent);
opacity: 0; transition: opacity 0.25s;
}
.card:hover::after { opacity: 0.6; }
@keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

.card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; }
.card-emoji { font-size: 1.6rem; line-height: 1; }
.strain-badge { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.55rem; border-radius: 100px; }
.badge-indica { background: rgba(167,139,250,0.12); color: var(–indica); }
.badge-sativa { background: rgba(251,146,60,0.12); color: var(–sativa); }
.badge-hybrid { background: rgba(168,255,110,0.1); color: var(–hybrid); }
.badge-cbd { background: rgba(56,189,248,0.1); color: var(–cbd); }

.card-name { font-family: ‘Syne’, sans-serif; font-size: 1.1rem; font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 0.15rem; }
.card-brand { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.04em; color: var(–text-dim); text-transform: uppercase; }
.card-strain-desc {
font-size: 0.72rem; line-height: 1.6; color: var(–text-mid);
padding: 0.6rem 0.75rem; background: var(–surface3);
border-left: 2px solid var(–strain-color, var(–accent));
border-radius: 0 var(–radius-sm) var(–radius-sm) 0;
}
.card-desc { font-size: 0.75rem; line-height: 1.65; color: var(–text-mid); }

/* PRICE TIERS */
.price-tiers { border: 1px solid var(–border); border-radius: var(–radius-sm); overflow: hidden; }
.tier-row {
display: flex; align-items: center; justify-content: space-between;
padding: 0.5rem 0.75rem; border-bottom: 1px solid var(–border); transition: background 0.15s;
}
.tier-row:last-child { border-bottom: none; }
.tier-row:hover { background: var(–surface3); }
.tier-label { font-size: 0.72rem; color: var(–text-mid); }
.tier-price { font-size: 0.78rem; font-weight: 600; color: var(–accent); font-family: ‘Syne’, sans-serif; }

.add-btn {
background: rgba(168,255,110,0.1); border: 1px solid rgba(168,255,110,0.2);
color: var(–accent); font-family: ‘Inter’, sans-serif; font-size: 0.7rem; font-weight: 600;
padding: 0.32rem 0.65rem; cursor: pointer; border-radius: var(–radius-sm); transition: all 0.15s; white-space: nowrap;
}
.add-btn:hover { background: rgba(168,255,110,0.18); border-color: rgba(168,255,110,0.4); }

.card-footer { display: flex; align-items: center; justify-content: flex-end; padding-top: 0.75rem; border-top: 1px solid var(–border); }
.availability { display: flex; align-items: center; gap: 0.35rem; font-size: 0.65rem; font-weight: 500; color: var(–text-dim); }
.dot { width: 6px; height: 6px; border-radius: 50%; background: var(–accent); box-shadow: 0 0 6px var(–accent); }
.dot.low { background: var(–sativa); box-shadow: 0 0 6px var(–sativa); }

/* EMPTY */
.empty { grid-column: 1/-1; padding: 5rem 2rem; text-align: center; color: var(–text-dim); }
.empty-icon { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4; }
.empty-title { font-family: ‘Syne’, sans-serif; font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; color: var(–text); }
.empty-sub { font-size: 0.72rem; }

/* FOOTER */
footer {
position: relative; z-index: 10; border-top: 1px solid var(–border);
padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
}
.disclaimer { font-size: 0.65rem; color: var(–text-dim); max-width: 600px; line-height: 1.6; }
.age-gate {
font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
color: var(–text-mid); background: var(–surface2); border: 1px solid var(–border-light);
padding: 0.4rem 0.9rem; border-radius: 100px;
}

/* CART BAR */
.cart-bar {
position: fixed; bottom: 0; left: 0; right: 0;
background: rgba(0,0,0,0.95); backdrop-filter: blur(20px);
border-top: 1px solid var(–border-light);
padding: 0.85rem 1.5rem; display: none; align-items: center; gap: 1rem; z-index: 100;
}
.cart-open-btn {
display: inline-flex; align-items: center; gap: 0.5rem;
background: var(–accent); color: #000; font-family: ‘Syne’, sans-serif;
font-size: 0.82rem; font-weight: 700; padding: 0.65rem 1.2rem;
border-radius: var(–radius-sm); border: none; cursor: pointer; transition: all 0.15s;
}
.cart-open-btn:hover { background: var(–accent2); }
.cart-badge {
background: #000; color: var(–accent); font-size: 0.65rem; font-weight: 700;
width: 18px; height: 18px; border-radius: 50%;
display: inline-flex; align-items: center; justify-content: center;
}
.cart-total-preview { font-size: 0.8rem; font-weight: 600; color: var(–text); }
.cart-total-preview span { color: var(–accent); }
.cashapp-quick-btn {
margin-left: auto; display: inline-flex; align-items: center; gap: 0.4rem;
background: #00D632; color: #000; font-family: ‘Inter’, sans-serif;
font-size: 0.78rem; font-weight: 700; padding: 0.6rem 1.1rem;
border-radius: var(–radius-sm); text-decoration: none; transition: all 0.15s; white-space: nowrap;
}
.cashapp-quick-btn:hover { background: #00f038; }
.square-quick-btn {
display: inline-flex; align-items: center; gap: 0.4rem;
background: #006AFF; color: #fff; font-family: ‘Inter’, sans-serif;
font-size: 0.78rem; font-weight: 700; padding: 0.6rem 1.1rem;
border-radius: var(–radius-sm); text-decoration: none; transition: all 0.15s; white-space: nowrap;
}
.square-quick-btn:hover { background: #0057d4; }

/* CART OVERLAY */
.cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 200; opacity: 0; pointer-events: none; transition: opacity 0.25s; }
.cart-overlay.open { opacity: 1; pointer-events: all; }

/* CART DRAWER */
.cart-drawer {
position: fixed; right: 0; top: 0; bottom: 0; width: 100%; max-width: 420px;
background: var(–surface); border-left: 1px solid var(–border);
z-index: 201; display: flex; flex-direction: column;
transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
}
.cart-drawer.open { transform: translateX(0); }
.cart-head {
display: flex; align-items: center; justify-content: space-between;
padding: 1.25rem 1.5rem; border-bottom: 1px solid var(–border);
}
.cart-title { font-family: ‘Syne’, sans-serif; font-size: 1.1rem; font-weight: 700; color: #fff; }
.cart-close {
width: 32px; height: 32px; background: var(–surface2); border: 1px solid var(–border-light);
border-radius: var(–radius-sm); color: var(–text-dim); cursor: pointer;
display: flex; align-items: center; justify-content: center; transition: all 0.15s; font-size: 0.9rem;
}
.cart-close:hover { color: var(–text); background: var(–surface3); }
.cart-items { flex: 1; overflow-y: auto; padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.cart-empty { text-align: center; padding: 3rem 1rem; color: var(–text-dim); font-size: 0.8rem; }
.cart-empty-icon { font-size: 2rem; margin-bottom: 0.75rem; opacity: 0.4; }
.cart-item {
background: var(–surface2); border: 1px solid var(–border); border-radius: var(–radius-sm);
padding: 0.85rem 1rem; display: flex; align-items: flex-start; gap: 0.75rem;
}
.ci-emoji { font-size: 1.4rem; flex-shrink: 0; line-height: 1; margin-top: 2px; }
.ci-info { flex: 1; min-width: 0; }
.ci-name { font-family: ‘Syne’, sans-serif; font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 0.15rem; }
.ci-tier { font-size: 0.7rem; color: var(–text-dim); margin-bottom: 0.3rem; }
.ci-qty { display: flex; align-items: center; gap: 0.4rem; margin-top: 0.4rem; }
.qty-btn {
width: 24px; height: 24px; background: var(–surface3); border: 1px solid var(–border-light);
border-radius: 4px; color: var(–text); cursor: pointer;
display: flex; align-items: center; justify-content: center; transition: all 0.12s; font-size: 0.85rem;
}
.qty-btn:hover { background: var(–border-light); }
.qty-num { font-size: 0.8rem; font-weight: 600; color: var(–text); min-width: 20px; text-align: center; }
.ci-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; }
.ci-remove { background: none; border: none; color: var(–text-dim); cursor: pointer; padding: 0.2rem; transition: color 0.15s; font-size: 0.85rem; }
.ci-remove:hover { color: #f87171; }
.ci-price { font-size: 0.85rem; font-weight: 600; color: var(–accent); }

/* CART FOOTER */
.cart-foot { padding: 1.25rem 1.5rem; border-top: 1px solid var(–border); display: flex; flex-direction: column; gap: 0.75rem; }
.cart-subtotal-row { display: flex; align-items: center; justify-content: space-between; }
.cart-subtotal-label { font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(–text-dim); }
.cart-subtotal-amount { font-family: ‘Syne’, sans-serif; font-size: 1.4rem; font-weight: 700; color: #fff; }
.cashapp-checkout-btn {
display: flex; align-items: center; justify-content: center; gap: 0.5rem;
background: #00D632; color: #000; font-family: ‘Syne’, sans-serif;
font-size: 0.9rem; font-weight: 700; padding: 0.85rem; border-radius: var(–radius-sm);
text-decoration: none; transition: all 0.15s; width: 100%;
}
.cashapp-checkout-btn:hover { background: #00f038; }
.square-checkout-btn {
display: flex; align-items: center; justify-content: center; gap: 0.5rem;
background: #006AFF; color: #fff; font-family: ‘Syne’, sans-serif;
font-size: 0.9rem; font-weight: 700; padding: 0.85rem; border-radius: var(–radius-sm);
text-decoration: none; transition: all 0.15s; width: 100%;
}
.square-checkout-btn:hover { background: #0057d4; }

/* ORDER FORM */
.order-form-section { display: flex; flex-direction: column; gap: 0.5rem; }
.order-form-label {
font-size: 0.72rem; font-weight: 700; color: #fbbf24;
background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.2);
border-radius: var(–radius-sm); padding: 0.6rem 0.75rem;
}
.order-disclaimer { font-size: 0.65rem; color: var(–text-dim); line-height: 1.5; }

.send-order-btn {
width: 100%; padding: 0.8rem; border: none; border-radius: var(–radius-sm);
font-family: ‘Syne’, sans-serif; font-size: 0.88rem; font-weight: 700;
cursor: pointer; transition: all 0.15s;
}
.send-order-btn.ready { background: var(–accent); color: #000; }
.send-order-btn.ready:hover { background: var(–accent2); }
.send-order-btn.disabled { background: var(–surface3); color: var(–text-dim); cursor: not-allowed; }
.send-order-btn.sent { background: rgba(168,255,110,0.15); color: var(–accent); border: 1px solid rgba(168,255,110,0.3); cursor: default; }
.send-order-note { font-size: 0.65rem; color: var(–text-dim); text-align: center; }

/* PAYMENT GATE */
.payment-gate { display: flex; flex-direction: column; gap: 0.6rem; }
.payment-gate-label {
font-size: 0.68rem; font-weight: 600; color: var(–text-dim);
text-align: center; padding: 0.4rem;
}
.payment-gate-label.unlocked { color: var(–accent); }
.cashapp-checkout-btn.locked,
.square-checkout-btn.locked { opacity: 0.4; cursor: not-allowed; }
.cashapp-checkout-btn.unlocked,
.square-checkout-btn.unlocked { opacity: 1; cursor: pointer; }
.cart-note { font-size: 0.65rem; color: var(–text-dim); text-align: center; line-height: 1.5; }

/* FULFILLMENT */
.fulfillment-section { display: flex; flex-direction: column; gap: 0.65rem; }
.fulfillment-label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(–text-dim); }
.method-toggle { display: flex; gap: 0.4rem; }
.method-btn {
flex: 1; padding: 0.55rem; border: 1px solid var(–border-light); border-radius: var(–radius-sm);
background: var(–surface2); color: var(–text-mid); font-family: ‘Inter’, sans-serif;
font-size: 0.75rem; font-weight: 600; cursor: pointer; text-align: center; transition: all 0.15s;
}
.method-btn.active { background: rgba(168,255,110,0.1); border-color: rgba(168,255,110,0.35); color: var(–accent); }
.location-info {
background: var(–surface3); border: 1px solid var(–border); border-radius: var(–radius-sm);
padding: 0.65rem 0.85rem; font-size: 0.72rem; color: var(–text-mid); line-height: 1.6;
}
.location-info strong { color: var(–text); font-weight: 600; display: block; margin-bottom: 0.15rem; }
.loc-tag {
display: inline-flex; align-items: center; gap: 0.3rem;
font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
color: var(–accent2); margin-bottom: 0.3rem;
}
.shipping-fields { display: flex; flex-direction: column; gap: 0.5rem; }
.field-input {
width: 100%; background: var(–surface2); border: 1px solid var(–border-light); border-radius: var(–radius-sm);
color: var(–text); font-family: ‘Inter’, sans-serif; font-size: 0.78rem;
padding: 0.6rem 0.8rem; outline: none; transition: border-color 0.2s;
}
.field-input:focus { border-color: rgba(168,255,110,0.4); box-shadow: 0 0 0 2px rgba(168,255,110,0.06); }
.field-input::placeholder { color: var(–muted); }
.field-row { display: flex; gap: 0.5rem; }
.field-row .field-input { flex: 1; }
.mixed-warning {
background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.2); border-radius: var(–radius-sm);
padding: 0.6rem 0.75rem; font-size: 0.68rem; color: #fbbf24; line-height: 1.5;
}

@media (max-width: 768px) {
header, main, footer { padding-left: 1.25rem; padding-right: 1.25rem; }
.logo { font-size: 1.3rem; }
}
</style>

</head>
<body>

<header>
  <div>
    <div class="logo-eyebrow">// Fine Cannabis</div>
    <div class="logo"><em>J-netics</em></div>
  </div>
  <div class="open-badge">Open Now &middot; 9am &ndash; 10pm</div>
</header>

<main>
  <div class="controls">
    <div class="search-wrap">
      <span class="search-icon">&#9906;</span>
      <input class="search-input" type="text" id="searchInput" placeholder="Search strains, brands&hellip;">
    </div>
    <select class="filter-select" id="sortSelect">
      <option value="default">Featured</option>
      <option value="name-asc">A &rarr; Z</option>
    </select>
    <select class="filter-select" id="typeFilter">
      <option value="all">All Types</option>
      <option value="indica">Indica</option>
      <option value="sativa">Sativa</option>
      <option value="hybrid">Hybrid</option>
    </select>
    <div class="result-count" id="resultCount"><span>0</span> products</div>
  </div>

  <div class="tabs" id="tabs">
    <button class="tab active" data-cat="all">All <span class="tab-count" id="cnt-all">0</span></button>
    <button class="tab" data-cat="flower">Flower <span class="tab-count" id="cnt-flower">0</span></button>
    <button class="tab" data-cat="concentrate">Concentrates <span class="tab-count" id="cnt-concentrate">0</span></button>
    <button class="tab" data-cat="preroll">Pre-Rolls <span class="tab-count" id="cnt-preroll">0</span></button>
  </div>

  <div class="grid" id="productGrid"></div>
</main>

<footer>
  <div class="disclaimer">For use by adults 21+ only. Keep out of reach of children. Cannabis may impair your ability to drive or operate machinery. Please consume responsibly.</div>
  <div class="age-gate">21+ Only</div>
</footer>

<!-- Cart Bar -->

<div class="cart-bar" id="cartBar">
  <button class="cart-open-btn" onclick="openCart()">
    &#x1F6D2; <span class="cart-total-preview" id="cartTotalPreview">Cart</span>
    <span class="cart-badge" id="cartCount">0</span>
  </button>
  <a class="cashapp-quick-btn" id="cashappQuick" href="https://cash.app/$jayj448" target="_blank">
    Pay $jayj448
  </a>
  <a class="square-quick-btn" id="squareQuick" href="https://checkout.square.site/merchant/ML068R1G918XR/checkout/7CZQWO7V2RUG7BK6JPORGD3A" target="_blank">
    &#x25A0; Card
  </a>
